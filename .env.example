# --- Backend session auth (shared with admin-app) ---
# The system dashboard authenticates against the NestJS backend. Individual
# admin accounts sign in at /login; the flow map + monitoring pages
# (users/deployments/activity) all sit behind that session.

# Backend origin the /api/* rewrite + auth route handlers proxy to.
API_PROXY_TARGET="https://api.devya-solutions.com"

# Session cookie name minted by the backend. Keep in sync with the backend +
# admin-app. Defaults to devya_session when unset.
SESSION_COOKIE_NAME="devya_session"

# Browser-side API base. Leave EMPTY for same-origin (/api/* → rewrite → backend)
# so the httpOnly session cookie travels with every request. Only set this to an
# absolute URL in local dev if you are not using the same-origin rewrite.
NEXT_PUBLIC_API_URL=""

# Optional: admin sign-in shown on the flow map page (CredentialsCard).
# The card renders nothing when these are unset. NEXT_PUBLIC_ vars are inlined
# into the client bundle at build time — anyone with page access can read them.
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=
