# Password users type at /login
SITE_PASSWORD=change-me

# Opaque session-cookie value. Rotate to force re-login. Any random string, e.g. `openssl rand -hex 32`.
SITE_AUTH_TOKEN=change-me-too

# Optional: admin sign-in shown on the flow-map page (CredentialsCard).
# The card renders nothing when these are unset. NEXT_PUBLIC_ vars are inlined
# into the client bundle at build time — anyone with page access can read them.
NEXT_PUBLIC_DEMO_EMAIL=
NEXT_PUBLIC_DEMO_PASSWORD=
